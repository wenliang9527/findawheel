# Optional: GitHub Personal Access Token. Without it, GitHub API is limited to 60 req/hour.
GITHUB_TOKEN=

# Optional: Exa API key for Web search (primary source, neural search).
# Get one at https://exa.ai
EXA_API_KEY=

# Optional: Tavily API key for Web search (fallback when Exa fails or quota exhausted).
# Get one at https://tavily.com
TAVILY_API_KEY=

# Default limit of wheels returned per query. Default: 20
FINDAWHEEL_LIMIT=20

# Per-source request timeout in milliseconds. Default: 8000
FINDAWHEEL_TIMEOUT_MS=8000

# Log level: error | warn | info | debug. Default: info
FINDAWHEEL_LOG_LEVEL=info
