# Optional: GitHub Personal Access Token. Without it, GitHub API is limited to 60 req/hour.
GITHUB_TOKEN=

# Optional: Exa API key for Web search (primary source, neural search).
# Get one at https://exa.ai
EXA_API_KEY=

# Optional: Tavily API key for Web search (fallback when Exa fails or quota exhausted).
# Get one at https://tavily.com
TAVILY_API_KEY=

# Optional: GitLab token (improves rate limit for GitLab search). Anonymous search works without it.
GITLAB_TOKEN=

# Optional: Gitee token (improves rate limit for Gitee search: 60/hour anonymous -> 5000/hour authenticated).
# Get one at https://gitee.com/profile/personal_access_tokens
GITEE_TOKEN=

# Optional: Libraries.io API key (enables multi-package-manager search: npm/pypi/rubygems/cargo/maven...).
# Without it, the Libraries.io adapter is skipped. Get one at https://libraries.io/account
LIBRARIES_IO_API_KEY=

# Optional: Your project's license (e.g., MIT, Apache-2.0, GPL-3.0).
# When set, search results include a licenseCheck field showing whether each wheel's license
# is compatible with yours (avoids license contamination). Leave empty to skip the check.
FINDAWHEEL_USER_LICENSE=

# Feedback storage directory. Default: ~/.findawheel/feedback/
# Stores user feedback (like/hide/click) persistently across sessions, used to adjust search ranking.
# No TTL — feedback accumulates until manually cleared.
# Windows paths require double backslashes (e.g., D:\\mydata\\findawheel-feedback).
FINDAWHEEL_FEEDBACK_DIR=

# Local cache for search results. Default: enabled.
FINDAWHEEL_CACHE_ENABLED=true

# Cache directory. Default: ~/.findawheel/cache/
# Override if you want cache on a different drive (e.g., D:\\findawheel-cache).
FINDAWHEEL_CACHE_DIR=

# Cache TTL in milliseconds. Default: 1 hour (3600000).
FINDAWHEEL_CACHE_TTL_MS=3600000

# Default limit of wheels returned per query. Default: 20
FINDAWHEEL_LIMIT=20

# Per-source request timeout in milliseconds. Default: 8000
FINDAWHEEL_TIMEOUT_MS=8000

# Log level: error | warn | info | debug. Default: info
FINDAWHEEL_LOG_LEVEL=info

# === Knowledge Base (search_knowledge tool) ===
# Enable the search_knowledge tool for searching local Markdown notes.
# Default: false (disabled — must explicitly enable to use the tool).
FINDAWHEEL_KB_ENABLED=false

# Knowledge base root directory (supports multiple, comma-separated).
# Examples: Obsidian vault path, Logseq folder, or any folder containing .md files.
# Multiple roots: /home/user/Documents/ObsidianVault,/home/user/Projects/team-wiki
# Windows: use double backslashes, e.g., D:\\Notes\\MyVault,E:\\TeamWiki
FINDAWHEEL_KB_ROOT=

# Max single .md file size in KB. Files larger than this are skipped (default: 100).
# Increase if your knowledge base contains large files with important content.
FINDAWHEEL_KB_MAX_FILE_KB=100

# Whether to enable disk cache for knowledge base search results.
# Default: false (each search re-scans disk to ensure latest content).
# Set to true to reuse findawheel's main cache (TTL 1h) — faster but may return stale results.
FINDAWHEEL_KB_CACHE_ENABLED=false
